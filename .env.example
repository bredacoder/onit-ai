# PostgreSQL connection URL (matches docker-compose db service credentials)
# sslmode=prefer is safe for localhost dev and production-safe (upgrades to TLS if available)
DATABASE_URL=postgres://onit:onit@localhost:5433/onit?sslmode=prefer

# Single-tenant user ID resolved by the CLI (Decision B in docs/decisions.md)
ONIT_USER_ID=your-user-id-here
